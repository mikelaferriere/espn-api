{
  "name": "@mikelaferriere/espn-api",
  "version": "0.9.6",
  "description": "Typescript library for accessing ESPN's Public API",
  "keywords": [],
  "author": "Mike Laferriere",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://git@github.com/mikelaferriere/espn-api.git"
  },
  "main": "build/index.js",
  "types": "build/dts",
  "files": [
    "build",
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "changeset": "changeset",
    "deploy": "tsc",
    "docs": "rm -rf docs && typedoc lib/index.ts --out docs --basePath /espn-api/",
    "format:check": "prettier . --check",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "predeploy": "rm -rf build",
    "precommit": "npm run format:check && npm run lint && npm run build && npm run test",
    "publish": "changeset publish",
    "test": "jest . --coverage"
  },
  "dependencies": {
    "axios": "1.12.2",
    "luxon": "3.7.2"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@types/jest": "29.1.1",
    "@types/luxon": "3.7.1",
    "@types/node": "20.19.20",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "esbuild": "0.25.10",
    "eslint": "8.57.0",
    "husky": "^9.1.7",
    "jest": "29.1.1",
    "nodemon": "3.1.10",
    "prettier": "3.6.2",
    "supertest": "7.1.4",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typedoc": "0.28.13",
    "typescript": "5.9.3"
  }
}
